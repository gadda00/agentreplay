# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml
*.cover

# Type checking
.mypy_cache/
.ruff_cache/

# Project-specific: cassettes are large; keep small examples in repo
# Cassette blobs (large payloads) are ignored by default, but committed
# cassettes under `cassettes/sample-*/` are tracked for CI regression.
cassettes/*.bin
cassettes/tmp-*/
cassettes/run-*/
!cassettes/.gitkeep
!cassettes/sample-001/**
!tests/cassettes/**

# OS
.DS_Store
Thumbs.db

# Logs
*.log
